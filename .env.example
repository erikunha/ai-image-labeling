# LLM provider — openai | anthropic | google  (default: openai)
# LLM_PROVIDER=openai

# OpenAI API key (required when provider=openai)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic API key (required when provider=anthropic)
# Get yours at: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-...

# Google AI API key (required when provider=google)
# Get yours at: https://aistudio.google.com/app/apikey
# GOOGLE_API_KEY=AIza...

# Optional overrides (all have sensible defaults)
# MODEL=gpt-4o                          # override default model for any provider
# INPUT_DIR=./input
# OUTPUT_DIR=./output
# CATEGORIES_CONFIG=./examples/categories.json
# BATCH_SIZE=20
# MAX_RETRIES=3
