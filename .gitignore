.DS_Store
Thumbs.db
.vscode/settings.json
*.log

# Coverage
coverage/
.nyc_output/

# Generated API docs
docs/api/

# TypeScript cache
*.tsbuildinfo

# Hook output (secrets-scanner, test-gate)
logs/

# Claude Code local overrides (machine-specific permissions)
.claude/settings.local.json
