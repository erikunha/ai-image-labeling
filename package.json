{
  "name": "ai-image-labeling",
  "version": "0.0.1",
  "description": "AI-powered CLI that uses LLM Vision APIs (OpenAI, Anthropic, Google) to classify, timestamp, and label images into named categories. Configurable taxonomy, temporal consensus, and a developer-friendly UX.",
  "type": "module",
  "main": "dist/sdk.js",
  "exports": {
    ".": "./dist/sdk.js",
    "./cli": "./dist/cli/index.js"
  },
  "bin": {
    "ai-image-labeling": "dist/cli/index.js"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@google/genai",
      "better-sqlite3",
      "protobufjs",
      "sharp"
    ]
  },
  "packageManager": "pnpm@11.0.8",
  "engines": {
    "node": ">=18",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "node --watch dist/cli/index.js",
    "start": "node dist/cli/index.js",
    "fixtures": "tsx scripts/generate-fixtures.ts",
    "pretest": "tsx scripts/generate-fixtures.ts",
    "readme:generate": "tsx scripts/gen-readme-flags.ts",
    "readme:check": "tsx scripts/gen-readme-flags.ts --check",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "benchmark": "tsx scripts/benchmark.ts",
    "benchmark:generate": "tsx scripts/generate-benchmark-fixtures.ts",
    "benchmark:update-baseline": "tsx scripts/benchmark.ts --update-baseline",
    "docs:generate": "typedoc",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run test:coverage",
    "mutate": "stryker run",
    "commit": "cz",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged",
    "pre-push": "pnpm run typecheck && pnpm test",
    "commit-msg": "commitlint --edit $1"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "keywords": [
    "ai",
    "openai",
    "anthropic",
    "google",
    "claude",
    "gemini",
    "gpt-4-vision",
    "cli",
    "image-processing",
    "typescript",
    "github-copilot",
    "image-organizer",
    "computer-vision"
  ],
  "files": [
    "dist/",
    "examples/",
    "README.md",
    "LICENSE"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "0.95.1",
    "@aws-sdk/client-bedrock-runtime": "^3.1045.0",
    "@aws-sdk/client-s3": "^3.1045.0",
    "@azure/storage-blob": "^12.31.0",
    "@google-cloud/storage": "^7.19.0",
    "@google-cloud/vertexai": "^1.12.0",
    "@google/generative-ai": "0.24.1",
    "@inquirer/input": "^5.0.12",
    "@inquirer/select": "^5.1.4",
    "chalk": "5.6.2",
    "chokidar": "5.0.0",
    "cli-progress": "3.12.0",
    "commander": "14.0.3",
    "dotenv": "17.4.2",
    "drizzle-orm": "^0.45.2",
    "exifr": "7.1.3",
    "file-type": "22.0.1",
    "fs-extra": "11.3.5",
    "openai": "6.37.0",
    "ora": "9.4.0",
    "p-limit": "7.3.0",
    "sharp": "0.34.5",
    "zod": "4.4.3"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.9.0"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.0",
    "@commitlint/config-conventional": "21.0.0",
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cli-progress": "3.11.6",
    "@types/fs-extra": "11.0.4",
    "@types/node": "25.6.2",
    "@typescript-eslint/eslint-plugin": "8.59.2",
    "@typescript-eslint/parser": "8.59.2",
    "@vitest/coverage-v8": "4.1.5",
    "commitizen": "4.3.1",
    "cz-conventional-changelog": "3.3.0",
    "eslint": "10.3.0",
    "globals": "^17.6.0",
    "lint-staged": "17.0.2",
    "prettier": "3.8.3",
    "simple-git-hooks": "2.13.1",
    "tsx": "4.21.0",
    "typedoc": "^0.28.19",
    "typescript": "6.0.3",
    "vite": "^8.0.14",
    "vitest": "4.1.5"
  }
}
